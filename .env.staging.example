# =============================================================================
# ProSell SaaS - Staging Environment (TEMPLATE)
# =============================================================================
# Copy this file to .env.staging on the staging host and fill in REAL values.
# Generate fresh secrets with: ./scripts/rotate-secrets.sh
# Full rotation runbook:       docs/SECRET_ROTATION.md
#
# ⚠️  NEVER commit .env.staging to git. It is gitignored by .env.* pattern.
# =============================================================================

ENVIRONMENT=staging
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# DATABASE - PostgreSQL 17
# Rotate at the provider, then paste the new value here.
# Generate a fresh one: ./scripts/rotate-secrets.sh db
# =============================================================================
POSTGRES_PASSWORD=ROTATE_ME_use_scripts_rotate-secrets.sh_db
DATABASE_URL=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@db:5432/prosell_staging
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# REDIS 7.4
# Rotate at the provider, then paste the new value here.
# Generate a fresh one: ./scripts/rotate-secrets.sh redis
# =============================================================================
REDIS_PASSWORD=ROTATE_ME_use_scripts_rotate-secrets.sh_redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=https://staging.prosell.com,https://prosell-staging.vercel.app

# =============================================================================
# JWT KEYS
# Generate a fresh pair: ./scripts/rotate-secrets.sh jwt
# Paste the new PEM into apps/api/keys/private.pem and public.pem on the host.
# Mounted read-only into the api container at /app/keys/.
# ⚠️  Rotating JWT keys logs EVERY active user out.
# =============================================================================
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem

# =============================================================================
# SECURITY
# =============================================================================
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
SESSION_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_2FA_ENABLED=true
FEATURE_OAUTH_GOOGLE=true
FEATURE_OAUTH_FACEBOOK=true
FEATURE_REGISTRATION_ENABLED=true
FEATURE_PASSWORD_RESET=true
FEATURE_BULK_UPLOAD_ENABLED=true
FEATURE_DEALER_ASSIGNMENT_ENABLED=true

# =============================================================================
# OAUTH - Google
# Generate a new client secret at:
#   https://console.cloud.google.com/apis/credentials
# Paste the new value into GOOGLE_OAUTH_CLIENT_SECRET below.
# =============================================================================
GOOGLE_OAUTH_CLIENT_ID=ROTATE_ME_google_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=ROTATE_ME_use_google_cloud_console
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# =============================================================================
# OAUTH - Facebook
# Generate a new app secret at:
#   https://developers.facebook.com/apps/<app-id>/settings/basic/
# =============================================================================
FACEBOOK_OAUTH_APP_ID=ROTATE_ME_facebook_app_id
FACEBOOK_OAUTH_APP_SECRET=ROTATE_ME_use_facebook_developers_console
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# =============================================================================
# EMAIL - SendGrid
# Generate a new API key at:
#   https://app.sendgrid.com/settings/api_keys
# Paste the new value into SENDGRID_API_KEY below.
# =============================================================================
USE_MOCK_EMAIL=false
SENDGRID_API_KEY=ROTATE_ME_use_sendgrid_console
SENDGRID_FROM_EMAIL=noreply@prosell.com
SENDGRID_FROM_NAME="ProSell Staging"
SENDGRID_REPLY_TO=support@prosell.com

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
RATE_LIMIT_TRUST_PROXY=false
BULK_UPLOAD_MAX_PER_MINUTE=10
BULK_UPLOAD_MAX_FILE_SIZE_MB=10
BULK_UPLOAD_MAX_ROWS=1000

# =============================================================================
# CORS
# =============================================================================
CORS_ALLOWED_ORIGINS=https://staging.prosell.com,https://prosell-staging.vercel.app
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# =============================================================================
# FILE UPLOAD
# =============================================================================
UPLOAD_MAX_FILE_SIZE_MB=5
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# =============================================================================
# MINIO (staging object storage — separate from prod)
# Generate fresh: ./scripts/rotate-secrets.sh minio
# =============================================================================
MINIO_ROOT_USER=ROTATE_ME_use_scripts_rotate-secrets.sh_minio
MINIO_ROOT_PASSWORD=ROTATE_ME_use_scripts_rotate-secrets.sh_minio

# =============================================================================
# ADMIN USER (used by init_data.py on container startup)
# Generate a fresh password: ./scripts/rotate-secrets.sh admin
# =============================================================================
ADMIN_EMAIL=admin@prosell.saas
ADMIN_PASSWORD=ROTATE_ME_use_scripts_rotate-secrets.sh_admin
