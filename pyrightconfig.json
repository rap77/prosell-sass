{
  "pythonVersion": "3.13",
  "typeCheckingMode": "standard",
  "include": [
    "apps/api/src",
    "apps/api/tests"
  ],
  "exclude": [
    "**/__pycache__",
    "**/node_modules",
    "**/.venv",
    "**/.*",
    "**/migrations"
  ],
  "venvPath": "apps/api",
  "venv": ".venv",
  "extraPaths": [
    "apps/api/src"
  ],
  "stubPath": "apps/api/tests/stubs"
}
