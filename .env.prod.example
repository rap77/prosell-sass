# =============================================================================
# .env.prod.example — ProSell SaaS producción
# Copiá este archivo a .env.prod y completá los valores reales
# NUNCA commitees .env.prod al repositorio
# =============================================================================

# ---------------------------------------------------------------------------
# Base de datos (usadas en docker-compose.prod.yml como ${DB_*})
# ---------------------------------------------------------------------------
DB_USER=prosell
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO_AQUI
DB_NAME=prosell_prod

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=CAMBIAR_PASSWORD_REDIS_SEGURO_AQUI

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ---------------------------------------------------------------------------
# JWT (rutas dentro del container — no cambiar)
# ---------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem

# ---------------------------------------------------------------------------
# Seguridad
# ---------------------------------------------------------------------------
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
SESSION_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# CORS — solo prosellweb.com
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=https://prosellweb.com,https://www.prosellweb.com

# ---------------------------------------------------------------------------
# Features
# ---------------------------------------------------------------------------
FEATURE_2FA_ENABLED=true
FEATURE_OAUTH_GOOGLE=true
FEATURE_OAUTH_FACEBOOK=false
FEATURE_REGISTRATION_ENABLED=true
FEATURE_PASSWORD_RESET=true
FEATURE_BULK_UPLOAD_ENABLED=true
FEATURE_DEALER_ASSIGNMENT_ENABLED=true

# ---------------------------------------------------------------------------
# Google OAuth — actualizá el Redirect URI en Google Cloud Console
# URI: https://api.prosellweb.com/api/auth/oauth/google/callback
# ---------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=TU_GOOGLE_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=TU_GOOGLE_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=https://api.prosellweb.com/api/auth/oauth/google/callback

# ---------------------------------------------------------------------------
# Facebook OAuth (deshabilitado por defecto en producción inicial)
# ---------------------------------------------------------------------------
FACEBOOK_OAUTH_APP_ID=
FACEBOOK_OAUTH_APP_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=https://api.prosellweb.com/api/auth/oauth/facebook/callback

# ---------------------------------------------------------------------------
# Email (SendGrid)
# ---------------------------------------------------------------------------
USE_MOCK_EMAIL=false
SENDGRID_API_KEY=TU_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=noreply@prosellweb.com
SENDGRID_FROM_NAME=ProSell
SENDGRID_REPLY_TO=support@prosellweb.com

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=20
RATE_LIMIT_BURST=10
RATE_LIMIT_TRUST_PROXY=true

# ---------------------------------------------------------------------------
# Bulk upload
# ---------------------------------------------------------------------------
BULK_UPLOAD_MAX_PER_MINUTE=10
BULK_UPLOAD_MAX_FILE_SIZE_MB=10
BULK_UPLOAD_MAX_ROWS=1000
