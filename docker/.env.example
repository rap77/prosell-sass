# =============================================================================
# Ngrok Configuration
# =============================================================================
# Get your free authtoken from: https://dashboard.ngrok.com/get-started/your-authtoken
# Sign up for free at: https://dashboard.ngrok.com/signup
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# =============================================================================
# Facebook OAuth Configuration
# =============================================================================
# Get credentials from: https://developers.facebook.com/apps
FACEBOOK_OAUTH_APP_ID=926649056406716
FACEBOOK_OAUTH_APP_SECRET=your_app_secret_here

# =============================================================================
# Google OAuth Configuration (Optional)
# =============================================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
