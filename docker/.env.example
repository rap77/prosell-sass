# =============================================================================
# Ngrok Configuration (TEMPLATE)
# =============================================================================
# Copy this file to .env on the docker host and fill in real values.
# Get a free authtoken at:  https://dashboard.ngrok.com/get-started/your-authtoken
# Sign up free at:         https://dashboard.ngrok.com/signup
#
# ⚠️  .env is gitignored (.env.* pattern). NEVER commit real values.
# =============================================================================

NGROK_AUTHTOKEN=ROTATE_ME_use_ngrok_dashboard

# =============================================================================
# Facebook OAuth Configuration (optional)
# Get credentials at: https://developers.facebook.com/apps
# App ID: public identifier (not a secret). App Secret: KEEP PRIVATE.
# =============================================================================
FACEBOOK_OAUTH_APP_ID=ROTATE_ME_facebook_app_id
FACEBOOK_OAUTH_APP_SECRET=ROTATE_ME_use_facebook_developers_console

# =============================================================================
# Google OAuth Configuration (optional)
# Get credentials at: https://console.cloud.google.com/apis/credentials
# =============================================================================
GOOGLE_CLIENT_ID=ROTATE_ME_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=ROTATE_ME_use_google_cloud_console
