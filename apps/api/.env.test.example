# Environment Configuration for Testing
ENVIRONMENT=testing
DEBUG=true

# Database - Test Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prosell_test
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis - Test Redis Instance
REDIS_URL=redis://localhost:6379/1

# API Configuration
API_HOST=0.0.0.0
API_PORT=8001
ALLOWED_ORIGINS_RAW=http://localhost:3000,http://localhost:8001

# Rate Limiting - Relaxed for Testing
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=memory
RATE_LIMIT_REQUESTS_PER_MINUTE=500
RATE_LIMIT_AUTH_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_BURST=100
RATE_LIMIT_BY_IP=true
RATE_LIMIT_BY_USER=true
RATE_LIMIT_TRUST_PROXY=false

# Rate Limiting - Test Exemptions
RATE_LIMIT_EXEMPT_IPS=127.0.0.1,::1
RATE_LIMIT_EXEMPT_RANGES=192.168.0.*,10.0.0.*

# Test API Key for Exemption
TEST_API_KEY=prosell-test-api-key-2026

# Security - Test Keys (NOT FOR PRODUCTION)
SECRET_KEY=test-secret-key-for-development-only-do-not-use-in-production-jwt-signing
ENCRYPTION_KEY=test-encryption-key-for-development-only-32bytes
REFRESH_SECRET_KEY=test-refresh-secret-key-for-development-only-do-not-use-in-production

# OAuth - Test Configuration
OAUTH_FACEBOOK_CLIENT_ID=test_facebook_client_id
OAUTH_FACEBOOK_CLIENT_SECRET=test_facebook_client_secret
OAUTH_FACEBOOK_REDIRECT_URI=http://localhost:3000/auth/facebook/callback

# JWT - Test Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Test Configuration
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# Email - Test Configuration (Mock)
EMAIL_BACKEND=mock
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@prosell.test
