# =============================================================================
# OAUTH 2.0 BACKEND CALLBACK SETTINGS
# =============================================================================
# These settings are for the backend OAuth 2.0 authorization code flow.
# The backend handles the OAuth handshake and sets httpOnly cookies.

# -----------------------------------------------------------------------------
# Google OAuth 2.0
# -----------------------------------------------------------------------------
# Get credentials from: https://console.cloud.google.com/apis/credentials
#
# 1. Create a new OAuth 2.0 Client ID
# 2. Application type: Web application
# 3. Authorized redirect URIs:
#    - Development: http://localhost:8000/api/v1/auth/oauth/google/callback
#    - Staging: https://api-staging.prosell.saas/api/v1/auth/oauth/google/callback
#    - Production: https://api.prosell.saas/api/v1/auth/oauth/google/callback
#
# Copy the Client ID and Client Secret below:

GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Backend callback URI (where Google redirects after authentication)
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# -----------------------------------------------------------------------------
# Facebook OAuth 2.0
# -----------------------------------------------------------------------------
# Get credentials from: https://developers.facebook.com/apps
#
# 1. Create a new app
# 2. Add Facebook Login product
# 3. Settings > Basic > Redirect OAuth URLs
#    - Development: http://localhost:8000/api/v1/auth/oauth/facebook/callback
#    - Staging: https://api-staging.prosell.saas/api/v1/auth/oauth/facebook/callback
#    - Production: https://api.prosell.saas/api/v1/auth/oauth/facebook/callback
#
# Copy the App ID and App Secret below:

FACEBOOK_OAUTH_APP_ID=your-facebook-app-id
FACEBOOK_OAUTH_APP_SECRET=your-facebook-app-secret

# Backend callback URI (where Facebook redirects after authentication)
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/facebook/callback

# -----------------------------------------------------------------------------
# Frontend URLs (Redirect after OAuth login)
# -----------------------------------------------------------------------------
# Where to redirect user after successful OAuth login
OAUTH_FRONTEND_SUCCESS_URL=http://localhost:3000/dashboard

# Where to redirect user after OAuth login failure (error appended)
OAUTH_FRONTEND_FAILURE_URL=http://localhost:3000/auth/login?error=

# -----------------------------------------------------------------------------
# OAuth Security Settings
# -----------------------------------------------------------------------------
# State token expiration in minutes (default: 10)
# State tokens are used for CSRF protection during OAuth flow
OAUTH_STATE_TOKEN_EXPIRE_MINUTES=10
